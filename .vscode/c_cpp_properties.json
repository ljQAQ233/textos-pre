            "cppStandard": "c++14",
            "intelliSenseMode": "linux-gcc-x64",
            "compileCommands": "${workspaceFolder}/Src/Utils/compile_commands.json",
            "compilerArgs": ["-include","${workspaceFolder}/Src/Include/TextOS/TextOS.h"]
        }
    ],
    "version": 4
}