{
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/Src/Include",
                "${workspaceFolder}/Src/Boot/Edk2/MdePkg/Include",
                "${workspaceFolder}/Src/Kernel/Arch/X64",
                "${workspaceFolder}/Src/Include/TextOS/Stdlib"
